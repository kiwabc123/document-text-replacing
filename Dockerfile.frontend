# Dockerfile for Next.js frontend (client-side only)
FROM node:20-alpine AS builder

WORKDIR /app

COPY .npmrc package*.json ./

RUN npm ci

COPY . .

RUN npm run build

# Production image
FROM node:20-alpine

WORKDIR /app

COPY .npmrc package*.json ./

RUN npm ci --omit=dev

COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public

EXPOSE 3000

CMD ["npm", "start"]
